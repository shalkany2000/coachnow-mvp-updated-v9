rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myRole() {
      return (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return myRole() == 'admin';
    }

    // GM has the same day-to-day operational access as admin (managing
    // bookings, verifying coaches, viewing everything) but NOT platform-
    // level settings like the commission rate — see /settings below, which
    // deliberately checks isAdmin() instead of isStaff().
    function isStaff() {
      return myRole() == 'admin' || myRole() == 'gm';
    }

    // The app matches "is this signed-in person the owner of this coach
    // profile" by userId OR by email (see CoachContext / CoachDashboard
    // etc.) — necessary because coach profiles seeded before this account
    // existed have a placeholder userId that doesn't match the real
    // Firebase Auth uid assigned on first login. Rules need the same dual
    // check, or a legitimate coach gets blocked from updating their own
    // bookings/profile.
    function ownsCoach(coachData) {
      return isSignedIn() && (
        coachData.userId == request.auth.uid ||
        coachData.email.lower() == request.auth.token.email.lower()
      );
    }

    // Defensive wrapper for checking coach ownership by id when the coach
    // document might not exist — accessing .data on a get() result for a
    // non-existent document can throw, and an error anywhere inside an OR
    // expression can cause the WHOLE expression to be denied even when a
    // different clause in that same OR would have legitimately passed.
    function ownsCoachById(coachId) {
      return exists(/databases/$(database)/documents/coaches/$(coachId)) &&
        ownsCoach(get(/databases/$(database)/documents/coaches/$(coachId)).data);
    }

    // NOTE ON READS: the app currently fetches each whole collection client-
    // side and filters in JavaScript (rather than using Firestore `where()`
    // queries scoped to the signed-in user). Firestore can't partially
    // filter results out of an unconstrained collection listener via rules
    // — a `list` request is either fully allowed or fully denied. So reads
    // here are gated on "must be signed in" rather than "must be YOUR data"
    // — that's a real, intentional limit: any logged-in user could read
    // other users' bookings/contact info if they wrote custom code to do
    // it, even though the app's own UI never lets them. A fully locked-down
    // version would mean rewriting the data-fetching to use scoped queries
    // (e.g. where('parentId','==',uid)) instead of "fetch everything".
    // WRITES below are fully locked down regardless, since those target one
    // specific document at a time and don't have this limitation.

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;
    }

    // The starter catalog/bookings are seeded once, the first time the
    // database is empty, using fixed known ids (coach1..coach8,
    // booking1..booking8) — see CoachContext/BookingContext. That seeding
    // can be triggered by any visitor, logged in or not, just by loading
    // the page before anyone else has. Rather than opening up create on
    // these collections entirely, these checks allow ONLY those exact
    // starter ids to be created freely; anything else still has to go
    // through the real ownership checks below.
    function isSeedCoachId(id) {
      return id in ['coach1','coach2','coach3','coach4','coach5','coach6','coach7','coach8'];
    }
    function isSeedBookingId(id) {
      return id in ['booking1','booking2','booking3','booking4','booking5','booking6','booking7','booking8'];
    }

    match /coaches/{coachId} {
      // Public browsing — anyone can see the coach catalog without logging in.
      allow read: if true;
      allow create: if isSeedCoachId(coachId) ||
        (isSignedIn() && request.resource.data.userId == request.auth.uid);
      // Anyone signed in can update ONLY rating/reviewCount (needed so a
      // parent leaving a review can update the coach's aggregate score) —
      // everything else about a coach's profile still requires ownership.
      // The rating-only check is listed first and is self-contained (no
      // get() calls), so it can never be sunk by an error from the other
      // clauses.
      allow update: if
        (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewCount'])) ||
        isStaff() || ownsCoach(resource.data);
      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn();
      allow create: if isSeedBookingId(bookingId) ||
        (isSignedIn() && request.resource.data.parentId == request.auth.uid);
      allow update: if isSignedIn() && (
        resource.data.parentId == request.auth.uid ||
        isStaff() ||
        ownsCoachById(resource.data.coachId)
      );
      allow delete: if false;
    }

    match /settings/{settingId} {
      // Read is public — the commission rate is shown in places like the
      // coach profile setup page and earnings breakdowns. Writing it is
      // intentionally admin-only (NOT isStaff()) — this is the actual
      // "sensitive setting" GM doesn't get access to.
      allow read: if true;
      // Auto-seeded once with fixed default values the first time the app
      // loads against an empty settings collection — same pattern as the
      // coach/booking starter catalog.
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      // Public — reviews are shown on coach profile pages to any visitor.
      allow read: if true;
      // The review's document id must be the booking id (enforced by the
      // app), and only the actual parent on a COMPLETED booking for that
      // exact coach can create it. Since `allow update` is false, trying
      // to write a second review at the same id is rejected automatically
      // — one review per booking, no separate uniqueness check needed.
      allow create: if isSignedIn() &&
        request.resource.data.parentId == request.auth.uid &&
        reviewId == request.resource.data.bookingId &&
        exists(/databases/$(database)/documents/bookings/$(reviewId)) &&
        get(/databases/$(database)/documents/bookings/$(reviewId)).data.parentId == request.auth.uid &&
        get(/databases/$(database)/documents/bookings/$(reviewId)).data.coachId == request.resource.data.coachId &&
        get(/databases/$(database)/documents/bookings/$(reviewId)).data.status == 'completed';
      allow update: if false;
      allow delete: if false;
    }
  }
}
